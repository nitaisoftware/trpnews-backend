# ============================================
# TRP NEWS - Environment Configuration
# Copy this to .env and fill in your values
# ============================================

# Server
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://trpnews.in

# PostgreSQL Database (Railway / Supabase / Render)
DATABASE_URL=postgresql://user:password@host:5432/trpnews

# Redis Cache (Upstash free tier recommended)
REDIS_URL=redis://default:password@hostname:6379

# Anthropic Claude API (for Bengali translation)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# JWT Secret (generate with: openssl rand -hex 64)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Admin credentials (hashed at first run)
ADMIN_EMAIL=admin@trpnews.in
ADMIN_PASSWORD=change-this-strong-password

# Fetch interval in minutes
FETCH_INTERVAL_MINUTES=15

# Max articles per fetch per source
MAX_ARTICLES_PER_SOURCE=10

# Google Analytics (optional)
GA_TRACKING_ID=G-XXXXXXXXXX
